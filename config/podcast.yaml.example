# Virtual EP — Podcast Configuration
#
# This file is generated by the podcast-init skill and read by every other
# skill in the toolkit. Copy this file to config/podcast.yaml and fill in
# your show's details, or run the podcast-init skill to walk through it.
#
# Anything left blank causes the dependent skill to either skip that step
# or fall back to a local-file output. Skills never fail because of a
# missing optional value — they degrade.

# ----------------------------------------------------------------------
# Show identity
# ----------------------------------------------------------------------
show:
  name: "The Build"
  tagline: "Business commentary for operators."
  audience: "Founders, executives, and senior operators in tech and SaaS."
  description: >
    Topical business commentary in the StarTalk format. Solo host carries
    the bulk of the talk time. Remote co-host throws articles, earnings
    reports, and follow-up questions to drive pacing. Tone is
    conversational, opinionated, and energetic.
  cadence: "weekly"          # weekly | biweekly | daily | monthly | adhoc
  target_runtime_minutes: 45
  episode_number_format: "EP###"   # e.g. EP001, EP012, EP142

# ----------------------------------------------------------------------
# Host
# ----------------------------------------------------------------------
host:
  name: ""
  short_bio: ""
  newsletter_tie_in:
    enabled: false
    name: "The Build"
    url: ""

# ----------------------------------------------------------------------
# Co-host
# ----------------------------------------------------------------------
cohost:
  name: ""
  email: ""
  contact_preference: "gmail"      # gmail | slack | none
  question_density_default: "standard"   # light | standard | heavy

# ----------------------------------------------------------------------
# Recording stack
# ----------------------------------------------------------------------
recording:
  platform: "Riverside"            # Riverside | Zencastr | SquadCast | local
  notes: ""

# ----------------------------------------------------------------------
# Transcription
# ----------------------------------------------------------------------
transcription:
  provider: "whisper-local"        # whisper-local | assemblyai | deepgram | rev
  api_key_env: ""                  # name of the env var holding the key
                                   # never store the key itself in this file

# ----------------------------------------------------------------------
# Publishing destinations
# ----------------------------------------------------------------------
publishing:
  primary_host: "buzzsprout"       # buzzsprout | spotify-for-podcasters | transistor | rss-com
  show_urls:
    spotify: ""
    apple: ""
    youtube: ""
    rss: ""

# ----------------------------------------------------------------------
# Analytics sources
# Skills pull early performance data from whichever of these is configured.
# ----------------------------------------------------------------------
analytics:
  spotify_for_podcasters: false
  apple_podcasts_connect: false
  youtube_studio: false
  buzzsprout: false

# ----------------------------------------------------------------------
# Brand assets
# ----------------------------------------------------------------------
brand:
  logo_path: "assets/logo.png"
  episode_art_template: "assets/episode-art.psd"
  color_palette:
    primary: "#000000"
    accent: "#ffffff"
  fonts:
    headline: ""
    body: ""

# ----------------------------------------------------------------------
# Recurring segments
# Define named segments the show runs in most episodes. The episode-program
# skill checks this list and offers to slot them into the run-of-show.
#
# Each segment carries a base block (id, name, target_seconds, description).
# An optional `populate` block adds source and generation rules — managed by
# the recurring-segment skill, read at run time by episode-program. Without
# a populate block, the segment slots in with its static description and
# generic ammunition.
# ----------------------------------------------------------------------
segments:
  - id: cold-open
    name: "Cold Open"
    target_seconds: 60
    description: "Hook the listener in under a minute. Tease the episode."
  - id: earnings-watch
    name: "Earnings Watch"
    target_seconds: 480
    description: "One earnings report, public-perception lens."
    populate:
      strategy: earnings-calendar
      source: "https://www.investing.com/earnings-calendar/"
      ammunition_count: 5
      question_count: 2
      voice_modifier: ""
      lookback_days: 7
  - id: founder-of-the-week
    name: "Founder of the Week"
    target_seconds: 360
    description: "One operator story with a sharp lesson."
    populate:
      strategy: topic-radar-category
      source: "founders"
      ammunition_count: 4
      question_count: 2
      voice_modifier: ""
      lookback_days: 7
  - id: closing-cta
    name: "Closing CTA"
    target_seconds: 45
    description: "Newsletter, subscribe, and one specific ask."

# ----------------------------------------------------------------------
# Topic radar — sources to scan
# ----------------------------------------------------------------------
topic_sources:
  # Local inboxes — pre-ranked topic feeds produced by pipelines OUTSIDE
  # this repo (research-ingest routines, voice-library wikis, company-brain
  # vaults). The hot-sheet skill reads these instead of fetching the web:
  # the upstream pipeline already scored and deduplicated, so skills select
  # from the index rather than re-ranking.
  #
  #   name:    label used in summaries and the `sources` input
  #   path:    absolute path to the index file (markdown table or list
  #            whose rows link to per-item node files)
  #   filters: optional frontmatter constraints applied to candidates;
  #            keys are matched against each node's frontmatter
  #
  # Example:
  #   local_inboxes:
  #     - name: external-voices
  #       path: /abs/path/to/talk_time/external_voices/INBOX.md
  #       filters:
  #         status: new
  #         purpose_tags_any: [riff_prompt, article_seed]
  #         brand_tags_any: [brg, book, newsletter]
  #         min_heat: 70
  local_inboxes: []
  rss_feeds:
    - "https://stratechery.com/feed/"
    - "https://www.bloomberg.com/feed/podcast/odd-lots.xml"
  websites:
    - "https://news.ycombinator.com"
    - "https://www.cnbc.com/markets/"
  earnings_calendars:
    - "https://www.investing.com/earnings-calendar/"
  newsletters: []
  twitter_lists: []
  default_lookback_days: 7

# ----------------------------------------------------------------------
# Output targets
# Where finished artifacts live. Leave a value blank to fall back to local
# files in outbox/.
# ----------------------------------------------------------------------
output_targets:
  google_drive:
    enabled: false
    run_of_show_folder_id: ""
    briefs_folder_id: ""
    cohost_brief_folder_id: ""
  google_sheets:
    editorial_calendar_id: ""
  google_calendar:
    calendar_id: ""
  notion:
    enabled: false
    editorial_database_id: ""

# ----------------------------------------------------------------------
# Distribution
# ----------------------------------------------------------------------
distribution:
  blotato:
    enabled: false
    accounts:
      linkedin: ""
      twitter: ""
      instagram: ""
      youtube_community: ""
  default_clip_count_target: 10
  clip_length_seconds:
    min: 30
    max: 90

# ----------------------------------------------------------------------
# Voice extensions
# The base style guide lives in style/voice.md and applies to every show.
# Add show-specific banned words, phrases, and required phrases here.
# ----------------------------------------------------------------------
voice:
  banned_words_extra: []
  banned_phrases_extra: []
  required_phrases: []
