# Per-user config — only the .example template is tracked
config/podcast.yaml

# Per-user voice fingerprint (built by the voice-fingerprint skill from the
# user's own transcripts; not appropriate to ship)
style/voice-fingerprint.md

# Outbox — generated by the skills at runtime, not appropriate to track
outbox/topics/*.md
outbox/episodes/EP*/
outbox/themes/*.md
outbox/editorial-calendar.csv

# But keep the empty directory structure so a fresh clone has the right shape
!outbox/.gitkeep
!outbox/topics/.gitkeep
!outbox/episodes/.gitkeep

# Recordings should never end up in the repo
recordings/
*.wav
*.mp3
*.m4a
*.flac

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Environment
.env
.env.local
